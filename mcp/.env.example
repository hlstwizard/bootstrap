# MCP daemon environment variables
# Copy to mcp/.env and fill actual values

CONTEXT7_API_KEY=
# MCP daemon bind/advertise host and default host for OpenCode URL substitution.
# Use 127.0.0.1 for local-only access, or host LAN IP for VM access.
# opencode/opencode.json now defaults to using {env:MCP_ENDPOINT_HOST}.
MCP_ENDPOINT_HOST=127.0.0.1
