{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "question": "allow"
  },
  "mcp": {
    "azure": {
      "type": "local",
      "command": ["uvx", "--from", "msmcp-azure", "azmcp", "server", "start"]
    },
    "awesome-copilot": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "ghcr.io/microsoft/mcp-dotnet-samples/awesome-copilot:latest"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "npx -y @upstash/context7-mcp --api-key $CONTEXT7_API_KEY"
      ]
    }
  },
  "plugin": [
    "understand-anything@git+https://github.com/Lum1104/Understand-Anything.git"
  ]
}
